# squid.conf — openSUSE Tumbleweed + VMs libvirt
# /etc/squid/squid.conf
# Date : 14/03/2026

#############################
# 1. GLOBAL / WORKERS       #
#############################

workers 4

cache_effective_user squid
cache_effective_group squid

# visible_hostname tumbleweed.local
coredump_dir /var/cache/squid
error_directory /usr/share/squid/errors/fr

client_db on
detect_broken_pconn on

# DNS via Unbound local (hôte + VMs)
dns_nameservers 127.0.0.1 ::1
dns_defnames on
dns_retransmit_interval 2 seconds
dns_timeout 5 minutes

# Anonymisation / robustesse
forwarded_for delete
half_closed_clients off
httpd_suppress_version_string on
ignore_unknown_nameservers on
pipeline_prefetch 1
retry_on_error on
uri_whitespace strip
via on

#############################
# 2. PORT D'ÉCOUTE          #
#############################

http_port 127.0.0.1:10000
http_port 192.168.1.181:10000

#############################
# 3. ACLs RÉSEAUX / PORTS   #
#############################

acl localnet src 0.0.0.1-0.255.255.255
acl localnet src 10.0.0.0/8
acl localnet src 100.64.0.0/10
acl localnet src 169.254.0.0/16
acl localnet src 172.16.0.0/12
acl localnet src 192.168.0.0/16
acl localnet src fc00::/7
acl localnet src fe80::/10

# acl libvirt src 192.168.122.0/24

acl SSL_ports port 443 563 8443 9443 8080

acl Safe_ports port 80
acl Safe_ports port 21
acl Safe_ports port 443
acl Safe_ports port 70
acl Safe_ports port 210
acl Safe_ports port 280
acl Safe_ports port 488
acl Safe_ports port 591
acl Safe_ports port 777
acl Safe_ports port 1025-65535

acl Safe_methods method GET POST OPTIONS CONNECT
acl CONNECT method CONNECT

#############################
# 4. ACLs IA / STREAMING    #
#############################

acl WebSocket_ports port 443 563 8443 9443 8080

acl ai_chatgpt           dstdomain .openai.com
acl ai_copilot_bing      dstdomain .bing.com
acl ai_copilot_sydney    dstdomain sydney.bing.com
acl ai_copilot_microsoft dstdomain s.copilot.microsoft.com
acl ai_gemini            dstdomain .google.com
acl ai_claude            dstdomain .anthropic.com .claude.ai
acl ai_perplexity        dstdomain .perplexity.ai
acl ai_deepseek          dstdomain .deepseek.com .deepseek.ai
acl ai_qwen              dstdomain .qwen.ai .tongyi.aliyun.com
acl ai_grok              dstdomain .x.ai

acl streaming_youtube  dstdomain .youtube.com .googlevideo.com
acl streaming_twitch   dstdomain .twitch.tv .ttvnw.net
acl streaming_vimeo    dstdomain .vimeo.com .vimeocdn.com
acl streaming_netflix  dstdomain .netflix.com .nflxvideo.net

#############################
# 5. LISTE ANTIPUB          #
#############################

acl yoyo_ads dstdomain "/etc/squid/acl/pgl_yoyo.domains"

#############################
# 6. RÈGLES D'ACCÈS         #
#############################

http_access deny !Safe_ports
http_access deny CONNECT !SSL_ports

http_access allow localhost manager
http_access deny manager

http_access deny yoyo_ads

http_access allow ai_chatgpt
http_access allow ai_copilot_bing
http_access allow ai_copilot_sydney
http_access allow ai_copilot_microsoft
http_access allow CONNECT ai_copilot_sydney WebSocket_ports
http_access allow CONNECT ai_copilot_microsoft WebSocket_ports
http_access allow ai_gemini
http_access allow ai_claude
http_access allow ai_perplexity
http_access allow ai_deepseek
http_access allow ai_qwen
http_access allow ai_grok

http_access allow streaming_youtube
http_access allow streaming_netflix
http_access allow streaming_twitch
http_access allow streaming_vimeo

http_access allow localhost
# http_access allow libvirt
http_access allow localnet

http_access deny all

#############################
# 7. CACHE                  #
#############################

cache_dir rock /var/cache/squid 1000 max-size=32768
cache_mem 2048 MB
quick_abort_min 1024 KB
maximum_object_size_in_memory 32 MB
maximum_object_size 256 MB
cache_swap_low 90
cache_swap_high 95

cache allow streaming_youtube
cache allow streaming_twitch
cache allow streaming_vimeo

#############################
# 8. LOGS                   #
#############################

cache_log /var/log/squid/cache.log
access_log /var/log/squid/access.log buffer-size=16KB on-error=drop
cache_store_log /var/log/squid/store.log

#############################
# 9. HEADERS ANONYMISATION  #
#############################

request_header_access Allow allow all
request_header_access Authorization allow all
request_header_access WWW-Authenticate allow all
request_header_access Proxy-Authorization allow all
request_header_access Proxy-Authenticate allow all
request_header_access Cache-Control allow all
request_header_access Content-Encoding allow all
request_header_access Content-Length allow all
request_header_access Content-Type allow all
request_header_access Host allow all
request_header_access Cookie allow all
request_header_access Accept allow all
request_header_access Accept-Encoding allow all
request_header_access Accept-Language allow all
request_header_access Connection allow all
request_header_access Transfer-Encoding allow all
request_header_access User-Agent deny all
request_header_access Referer deny all
request_header_access From deny all
request_header_access To deny all
request_header_access All deny all

reply_header_access Allow allow all
reply_header_access WWW-Authenticate allow all
reply_header_access Proxy-Authenticate allow all
reply_header_access Cache-Control allow all
reply_header_access Content-Encoding allow all
reply_header_access Content-Length allow all
reply_header_access Content-Type allow all
reply_header_access Content-Language allow all
reply_header_access Expires allow all
reply_header_access Last-Modified allow all
reply_header_access Location allow all
reply_header_access Set-Cookie allow all
reply_header_access Transfer-Encoding allow all
reply_header_access All deny all

#############################
# 10. RAFRAÎCHISSEMENT      #
#############################

refresh_pattern ^ftp:                     1440  20% 10080
refresh_pattern ^gopher:                  1440   0% 1440
refresh_pattern -i (/cgi-bin/|\?)            0   0%    0
refresh_pattern -i \.(mp4|mkv|flv|avi)$  1440  90% 525600
refresh_pattern -i \.(jpg|jpeg|png|gif)$  1440  90% 525600
refresh_pattern .                            0  20% 4320

#############################
# 11. COMMANDES UTILES      #
#############################

# sudo squid -k parse 2>&1 | grep -E "(ERROR|WARNING|FATAL)"
# sudo squid -k reconfigure
# sudo systemctl restart squid
# curl -x http://127.0.0.1:3128 -I https://www.perplexity.ai
